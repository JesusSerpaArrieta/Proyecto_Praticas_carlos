# Opción 1: URL completa (recomendado para Render/Neon)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Opción 2: Variables separadas (para desarrollo local)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=rental_management
# DB_USER=postgres
# DB_PASS=postgres

# SSL — poner true en producción (Neon lo requiere)
DB_SSL=false

JWT_SECRET=your_jwt_secret_here_change_in_production
PORT=3000
ADMIN_EMAIL=admin@rental.com
ADMIN_PASSWORD=Admin123!
